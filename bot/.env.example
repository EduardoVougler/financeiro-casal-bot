# Copie para .env e preencha. NUNCA versione o .env com valores reais.

# Token do bot (do @BotFather)
TELEGRAM_TOKEN=8763978662:AAF...xyz

# Chave da API da Anthropic (console.anthropic.com → API Keys)
ANTHROPIC_API_KEY=sk-ant-...

# Chave da Groq para transcrição de áudio (console.groq.com → API Keys).
# Opcional: sem ela, áudio é recusado, mas texto e foto funcionam.
GROQ_API_KEY=gsk_...
STT_MODEL=whisper-large-v3-turbo

# Chats autorizados (Eduardo e Maria), separados por vírgula.
ALLOWED_CHAT_IDS=111111111,222222222

# Para quem enviar os PDFs automáticos (opcional; default = primeiro autorizado)
REPORT_CHAT_ID=

# Modelo (opcional)
MODEL=claude-opus-4-8

# Fuso e agendamento (opcionais)
TZ=America/Fortaleza
# Fechamento mensal: dia 1 às 9h fecha o mês anterior
MONTHLY_DAY=1
MONTHLY_HOUR=9
# Fechamento anual: sempre em 31/12, à hora abaixo (20h)
ANNUAL_HOUR=20
